---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { formatQty } from '../../lib/format';

export async function getStaticPaths() {
  const recipes = await getCollection('recipes');
  return recipes.map((recipe) => ({
    params: { slug: recipe.id },
    props: { recipe },
  }));
}

const { recipe } = Astro.props;
const { Content } = await render(recipe);
const d = recipe.data;
---
<Layout title={d.title} description={d.description} image={d.image}>
  {d.image && <div class="hero" style={`background-image: url('${d.image}')`}></div>}

  <h1>{d.title}</h1>
  <p style="color: var(--muted); font-size: 1.05rem;">{d.description}</p>

  <div class="meta-strip">
    {d.prepTime && <span>Prep <strong>{d.prepTime}</strong></span>}
    {d.cookTime && <span>Cook <strong>{d.cookTime}</strong></span>}
    {d.cuisine && <span>Cuisine <strong>{d.cuisine}</strong></span>}
    <span>
      Servings
      <span class="scaler" data-base-servings={d.servings}>
        <button type="button" data-act="dec" aria-label="Fewer servings">−</button>
        <span class="value" id="servings-value">{d.servings}</span>
        <button type="button" data-act="inc" aria-label="More servings">+</button>
      </span>
    </span>
    {d.tags.length > 0 && (
      <span>{d.tags.map((t) => <span class="tag">{t}</span>)}</span>
    )}
  </div>

  <h2>Shopping list</h2>
  <ul class="ingredients" id="ingredients">
    {d.ingredients.map((ing, i) => (
      <li data-qty={ing.qty ?? ''} data-unit={ing.unit ?? ''}>
        <input type="checkbox" id={`ing-${i}`} />
        <label for={`ing-${i}`}>
          {ing.qty !== null && (
            <span class="qty"><span class="qty-value">{formatQty(ing.qty)}</span>{ing.unit ? ` ${ing.unit}` : ''}</span>
          )}
          {' '}{ing.item}
          {ing.note && <span class="note"> ({ing.note})</span>}
        </label>
      </li>
    ))}
  </ul>

  <div class="prose">
    <Content />
  </div>

  {d.sources && d.sources.length > 0 && (
    <div class="sources">
      Adapted from: {d.sources.map((s, i) => (
        <>
          <a href={s.url} target="_blank" rel="noopener">{s.title}</a>{i < d.sources!.length - 1 ? ', ' : ''}
        </>
      ))}
    </div>
  )}
</Layout>

<script>
  import { formatQty } from '../../lib/format';

  const scaler = document.querySelector<HTMLElement>('.scaler');
  if (scaler) {
    const base = parseInt(scaler.dataset.baseServings ?? '1', 10);
    const valueEl = document.getElementById('servings-value')!;
    const items = document.querySelectorAll<HTMLLIElement>('#ingredients li');
    let current = base;

    function render() {
      valueEl.textContent = String(current);
      const ratio = current / base;
      items.forEach((li) => {
        const rawQty = li.dataset.qty;
        if (!rawQty) return;
        const qtyEl = li.querySelector<HTMLElement>('.qty-value');
        if (!qtyEl) return;
        const scaled = parseFloat(rawQty) * ratio;
        qtyEl.textContent = formatQty(scaled);
      });
    }

    scaler.querySelector('[data-act="inc"]')?.addEventListener('click', () => {
      if (current < 99) { current += 1; render(); }
    });
    scaler.querySelector('[data-act="dec"]')?.addEventListener('click', () => {
      if (current > 1) { current -= 1; render(); }
    });
  }

  document.querySelectorAll<HTMLInputElement>('#ingredients input[type="checkbox"]').forEach((cb) => {
    cb.addEventListener('change', () => {
      cb.closest('li')?.classList.toggle('checked', cb.checked);
    });
  });
</script>
