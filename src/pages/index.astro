---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const recipes = (await getCollection('recipes')).sort(
  (a, b) => b.data.createdAt.valueOf() - a.data.createdAt.valueOf(),
);

const mealTypes = Array.from(new Set(recipes.map((r) => r.data.mealType).filter(Boolean))) as string[];
---
<Layout title="Recipes" description="Personal recipe collection." wide={true}>
  <div class="controls">
    <input id="search" type="search" placeholder="Search recipes…" autocomplete="off" />
    <button class="chip" data-meal="all" aria-pressed="true">All</button>
    {mealTypes.map((m) => (
      <button class="chip" data-meal={m} aria-pressed="false">{m}</button>
    ))}
  </div>

  {recipes.length === 0 && (
    <p style="color: var(--muted); text-align: center; padding: 3rem 0;">
      No recipes yet. Use the <code>recipe-publish</code> skill to add one.
    </p>
  )}

  <div class="grid" id="grid">
    {recipes.map((r) => (
      <a class="card" href={`/recipes/${r.id}/`} data-title={r.data.title.toLowerCase()} data-tags={r.data.tags.join(' ').toLowerCase()} data-meal={r.data.mealType ?? ''}>
        <div class="thumb" style={r.data.image ? `background-image: url('${r.data.image}')` : ''}></div>
        <div class="body">
          <h3>{r.data.title}</h3>
          <div class="meta">
            {r.data.cuisine && <span>{r.data.cuisine}</span>}
            {r.data.cuisine && r.data.cookTime && <span> · </span>}
            {r.data.cookTime && <span>{r.data.cookTime}</span>}
          </div>
        </div>
      </a>
    ))}
  </div>
</Layout>

<script>
  const search = document.getElementById('search') as HTMLInputElement;
  const chips = document.querySelectorAll<HTMLButtonElement>('.chip');
  const cards = document.querySelectorAll<HTMLAnchorElement>('#grid .card');
  let activeMeal = 'all';

  function apply() {
    const q = search.value.trim().toLowerCase();
    cards.forEach((c) => {
      const title = c.dataset.title ?? '';
      const tags = c.dataset.tags ?? '';
      const meal = c.dataset.meal ?? '';
      const matchQ = !q || title.includes(q) || tags.includes(q);
      const matchMeal = activeMeal === 'all' || meal === activeMeal;
      c.style.display = matchQ && matchMeal ? '' : 'none';
    });
  }

  search?.addEventListener('input', apply);

  chips.forEach((chip) => {
    chip.addEventListener('click', () => {
      chips.forEach((c) => c.setAttribute('aria-pressed', 'false'));
      chip.setAttribute('aria-pressed', 'true');
      activeMeal = chip.dataset.meal ?? 'all';
      apply();
    });
  });
</script>
